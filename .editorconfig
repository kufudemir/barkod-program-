root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json,xml}]
indent_size = 2

[*.kt]
indent_size = 4

[*.kts]
indent_size = 4

[*.php]
indent_size = 4

[*.blade.php]
indent_size = 4

